# Public Expo client variables.
# These are safe to expose in the browser/mobile client.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SITE_URL=https://athmira.com
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://athmira.com/auth/callback

# Cloudflare Turnstile public site key for web auth forms.
# You may also keep TURNSTILE_SITE_KEY in .env.local; app.config.js
# maps it into Expo extra without exposing TURNSTILE_SECRET_KEY.
EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# Optional local aliases supported by apps/app/app.config.js.
# Use these only in .env.local if your platform provides them.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# TURNSTILE_SITE_KEY=

# Server-only secrets. Keep these in Supabase/Cloudflare/Vercel secret
# settings and never expose them as EXPO_PUBLIC_* values.
# TURNSTILE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=
# SUPABASE_JWT_SECRET=
# POSTGRES_URL=
