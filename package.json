{
  "name": "athmira",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @athmira/app",
    "web": "npm run web -w @athmira/app",
    "build": "npm run build -w @athmira/app",
    "ios": "npm run ios -w @athmira/app",
    "ios:xcode": "npm run ios:xcode -w @athmira/app",
    "ios:archive": "npm run ios:archive -w @athmira/app",
    "android": "npm run android -w @athmira/app",
    "android:studio": "npm run android:studio -w @athmira/app",
    "android:bundle": "npm run android:bundle -w @athmira/app",
    "android:apk": "npm run android:apk -w @athmira/app",
    "expo:check": "npm run expo:check -w @athmira/app",
    "lint": "npm run lint -w @athmira/app",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "react-native": "0.83.6"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
