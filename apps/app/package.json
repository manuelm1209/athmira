  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "dev": "expo start",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "expo:check": "expo install --check",
    "lint": "expo lint",
    "native:prebuild": "expo prebuild",
    "native:prebuild:android": "expo prebuild --platform android",
    "native:prebuild:ios": "expo prebuild --platform ios",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@athmira/aero-engine": "0.1.0",
    "@athmira/ai-engine": "0.1.0",
    "@athmira/fit-engine": "0.1.0",
    "@athmira/nutrition-engine": "0.1.0",
    "@athmira/pose-engine": "0.1.0",
    "@athmira/supabase": "0.1.0",
    "@athmira/types": "0.1.0",
    "@athmira/ui": "0.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
