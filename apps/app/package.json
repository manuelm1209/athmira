{
  "name": "@athmira/app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "ios:device": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios --device",
    "ios:release": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios --configuration Release",
    "ios:archive": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 xcodebuild -workspace ios/athmira.xcworkspace -scheme athmira -configuration Release -destination 'generic/platform=iOS' -archivePath ios/build/athmira.xcarchive archive",
    "ios:xcode": "open ios/athmira.xcworkspace",
    "ios:pods": "cd ios && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 pod install",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "android:apk": "cd android && ./gradlew assembleRelease",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "android:studio": "open -a 'Android Studio' android",
    "android:clean": "cd android && ./gradlew clean",
    "expo:check": "expo install --check",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@athmira/aero-engine": "0.1.0",
    "@athmira/ai-engine": "0.1.0",
    "@athmira/fit-engine": "0.1.0",
    "@athmira/nutrition-engine": "0.1.0",
    "@athmira/pose-engine": "0.1.0",
    "@athmira/supabase": "0.1.0",
    "@athmira/types": "0.1.0",
    "@athmira/ui": "0.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "expo": "~55.0.26",
    "expo-camera": "~55.0.19",
    "expo-constants": "^55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-keep-awake": "~55.0.8",
    "expo-linking": "^55.0.15",
    "expo-pose-landmarker": "file:./modules/expo-pose-landmarker",
    "expo-router": "~55.0.16",
    "expo-status-bar": "^55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "^55.0.21",
    "eslint-config-expo": "~55.0.1",
    "typescript": "^5.9.3"
  }
}
