{
  "expo": {
    "name": "athmira",
    "slug": "athmira",
    "scheme": "athmira",
    "version": "0.1.0",
    "platforms": ["ios", "android", "web"],
    "orientation": "default",
    "icon": "./assets/icon.png",
    "primaryColor": "#00857d",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "newArchEnabled": true,
    "androidStatusBar": {
      "barStyle": "dark-content"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://athmira.com"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "athmira uses the camera only inside analysis flows to provide preliminary bike fit and aero posture guidance.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ]
    ],
    "ios": {
      "buildNumber": "1",
      "bundleIdentifier": "com.athmira.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "athmira uses the camera only inside analysis flows to provide preliminary bike fit and aero posture guidance.",
        "UIRequiresFullScreen": false
      }
    },
    "android": {
      "versionCode": 1,
      "package": "com.athmira.app",
      "allowBackup": false,
      "blockedPermissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111820"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    }
  }
}
