{
  "expo": {
    "name": "Athmira",
    "slug": "athmira",
    "scheme": "athmira",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://athmira.com"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Athmira uses the camera to provide preliminary bike fit and aero posture guidance."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.athmira.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Athmira uses the camera to provide preliminary bike fit and aero posture guidance."
      }
    },
    "android": {
      "package": "com.athmira.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}
