# Dependencies
node_modules/
**/node_modules/

# Expo / React Native Web build output
.expo/
dist/
web-build/
apps/**/dist/
apps/**/web-build/

# Expo native prebuild / React Native generated artifacts
# The android/ and ios/ folders are regenerated by `npm run native:prebuild`
# from app.json + config plugins. Do not commit them — this project stays
# on Expo managed and treats native code as a build output.
android/
ios/
apps/**/android/
apps/**/ios/
# But DO keep local Expo Modules' native source under modules/ — these are
# hand-written, committed source code, not Expo's generated native projects.
!apps/**/modules/**/android/
!apps/**/modules/**/ios/

# TFLite models (binary, downloaded from official sources — see
# apps/app/assets/models/README.md for download instructions).
apps/app/assets/models/*.tflite

# Xcode / CocoaPods
*.xcworkspace/
*.xcuserstate
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
xcuserdata/

# Gradle
.gradle/
local.properties
*.keystore
*.jks

# Local signing / service credentials
*.p8
*.p12
*.mobileprovision
*.provisionprofile

# Local Supabase email templates
supabase/email-templates/

# Playwright artifacts and auth state
playwright-report/
test-results/
blob-report/
.playwright-cl*
.playwright-*/
playwright/.auth/*.json
playwright/.auth/*.state
playwright/.auth/*.storage

# Vercel / build caches
.vercel/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
