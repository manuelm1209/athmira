# Dependencies
node_modules/
**/node_modules/

# Expo / React Native Web build output
.expo/
dist/
web-build/
apps/**/dist/
apps/**/web-build/

# Local Expo Modules' native source under modules/ stays committed.
# (Bare workflow: apps/app/ios and apps/app/android are also committed —
# build artifacts inside them are ignored individually below.)
!apps/**/modules/**/android/
!apps/**/modules/**/ios/

# Build artifacts from local Expo Modules' gradle/Xcode compiles
apps/**/modules/**/android/build/
apps/**/modules/**/android/.gradle/
apps/**/modules/**/ios/build/
apps/**/modules/**/ios/Pods/

# TFLite models (binary, downloaded from official sources — see
# apps/app/assets/models/README.md for download instructions).
apps/app/assets/models/*.tflite

# iOS build artifacts (source files, Podfile, Podfile.lock and project files
# stay committed; the rest is regenerated by `pod install` / Xcode).
apps/app/ios/build/
apps/app/ios/Pods/
apps/app/ios/DerivedData/
apps/app/ios/*.xcuserstate
apps/app/ios/**/xcuserdata/

# Generic Xcode user-state — keeps stray workspaces clean
*.xcuserstate
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
xcuserdata/

# Android build artifacts (source files, gradle wrapper, build.gradle
# stay committed; the rest is regenerated by Gradle / Android Studio).
apps/app/android/build/
apps/app/android/app/build/
apps/app/android/.gradle/
apps/app/android/.idea/
apps/app/android/local.properties
apps/app/android/captures/
apps/app/android/app/release/

# Generic Gradle / Android user state
.gradle/
local.properties

# Android signing (NEVER commit)
apps/app/android/keystore.properties
apps/app/android/app/*.keystore
apps/app/android/app/*.jks
*.keystore
*.jks

# Local signing / service credentials
*.p8
*.p12
*.mobileprovision
*.provisionprofile

# Local Supabase email templates
supabase/email-templates/

# Playwright artifacts and auth state
playwright-report/
test-results/
blob-report/
.playwright-cl*
.playwright-*/
playwright/.auth/*.json
playwright/.auth/*.state
playwright/.auth/*.storage

# Vercel / build caches
.vercel/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Source MediaPipe model download (kept locally only — copies committed inside
# apps/app/modules/expo-pose-landmarker/{ios,android}/.../)
/pose_landmarker_lite.task
